// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model ProfilSejarah {
  id        Int      @id @default(autoincrement())
  foto      String?
  konten    String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?
}

model ProfilVisiMisi {
  id        Int      @id @default(autoincrement())
  visi      String   @db.Text
  misi      String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?
}

model ProfilStrukturOrganisasi {
  id        Int      @id @default(autoincrement())
  foto      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?
}

model MajelisLembaga {
  id            Int      @id @default(autoincrement())
  slug          String   @unique
  nama          String
  deskripsi     String   @db.Text
  namaKetua     String
  bioKetua      String   @db.Text
  fotoKetua     String?
  sampulMajelis String?
  videoProfil   String?
  artikelKegiatan ArtikelKegiatan[]
  programKerja  ProgramKerja[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  deletedAt     DateTime?
}

model ArtikelKegiatan {
  id               Int            @id @default(autoincrement())
  slug             String         @unique
  judul            String
  tanggal          DateTime
  penulis          String
  deskripsi        String         @db.Text
  sampul           String
  majelisLembagaId Int
  majelisLembaga   MajelisLembaga @relation(fields: [majelisLembagaId], references: [id])
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  deletedAt        DateTime?
}

model ProgramKerja {
  id               Int            @id @default(autoincrement())
  slug             String         @unique
  judul            String
  majelisLembagaId Int
  majelisLembaga   MajelisLembaga @relation(fields: [majelisLembagaId], references: [id])
  foto             String
  deskripsi        String         @db.Text
  kegiatan         Kegiatan[]
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  deletedAt        DateTime?
}

model Kegiatan {
  id             Int          @id @default(autoincrement())
  slug           String       @unique
  judul          String
  foto           String[]
  deskripsi      String       @db.Text
  tanggal        DateTime
  programKerjaId Int
  programKerja   ProgramKerja @relation(fields: [programKerjaId], references: [id])
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?
}

model AuditLog {
  id         Int      @id @default(autoincrement())
  entityName String
  entityId   Int
  action     String
  changes    Json?
  createdAt  DateTime @default(now())
}
